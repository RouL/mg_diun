TZ="utc"
LOG_LEVEL="info"
LOG_JSON=false


#DIUN_WATCH_WORKERS=10
DIUN_WATCH_SCHEDULE=0 */6 * * *
#DIUN_WATCH_JITTER=30s
#DIUN_WATCH_FIRSTCHECKNOTIF=false
#DIUN_WATCH_RUNONSTARTUP=true
#DIUN_WATCH_COMPAREDIGEST=true
#DIUN_WATCH_HEALTHCHECKS_BASEURL=
#DIUN_WATCH_HEALTHCHECKS_UUID=
#DIUN_WATCH_HEALTHCHECKS_UUIDFILE=


#DIUN_DEFAULTS_WATCHREPO=false
#DIUN_DEFAULTS_NOTIFYON=new,update
#DIUN_DEFAULTS_MAXTAGS=0
#DIUN_DEFAULTS_SORTTAGS=reverse
#DIUN_DEFAULTS_INCLUDETAGS=
#DIUN_DEFAULTS_EXCLUDETAGS=
#DIUN_DEFAULTS_METADATA_FOO=


DIUN_METRICS_ENABLED=false


DIUN_NOTIF_TELEGRAM_TOKEN=
#DIUN_NOTIF_TELEGRAM_TOKENFILE=
DIUN_NOTIF_TELEGRAM_CHATIDS=
#DIUN_NOTIF_TELEGRAM_CHATIDSFILE=
#DIUN_NOTIF_TELEGRAM_TEMPLATEBODY="Docker tag {{ if .Entry.Image.HubLink }}[{{ .Entry.Image }}]({{ .Entry.Image.HubLink }}){{ else }}{{ .Entry.Image }}{{ end }} which you subscribed to through {{ .Entry.Provider }} provider has been {{ if (eq .Entry.Status "new") }}newly added{{ else }}updated{{ end }} on {{ escapeMarkdown .Meta.Hostname }}."
#DIUN_NOTIF_TELEGRAM_DISABLENOTIFICATION=false


DIUN_PROVIDERS_DOCKER=true
DIUN_PROVIDERS_DOCKER_WATCHBYDEFAULT=true
#DIUN_PROVIDERS_DOCKER_WATCHSTOPPED=false

